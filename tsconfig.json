{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/core/colors/figma-*.ts",
    "src/core/colors/color-storage.ts",
    "src/core/typography/typography-figma-*.ts",
    "src/core/typography/typography-fonts.ts",
    "src/core/typography/typography-mappings.ts",
    "src/core/typography/ensure-core-lineheight-vars.ts",
    "src/core/typography/type-scale-*-ui.ts"
  ]
}
